@page
@model FlyJusticeLite.Pages.ServicesModel
@{
    ViewData["Title"] = "Services";
    ViewData["MetaDescription"] = "Flight compensation services for delays, cancellations, missed connections, denied boarding, and passenger care.";
}

<section class="container stack-lg">
    <div class="page-heading split">
        <div>
            <p class="eyebrow">Our services</p>
            <h1>One workflow for disrupted passengers.</h1>
            <p>FlyJustice Lite combines eligibility checks, evidence upload, claim tracking, and admin review tools.</p>
        </div>
        <a class="button button-primary" asp-page="/Claims/Submit">Submit a claim</a>
    </div>

    <div class="content-grid">
        @foreach (var service in Model.Services)
        {
            <article class="content-card">
                <h2>@service.Title</h2>
                <p>@service.Description</p>
                <a class="text-link" href="@Url.Page(service.Page, new { slug = service.Slug })">@service.LinkText</a>
            </article>
        }
    </div>

    <section class="section-band">
        <div class="page-heading centered">
            <p class="eyebrow">How it works</p>
            <h2>From flight details to claim status.</h2>
            <p>The passenger handles the first two steps. The claim team can manage review and status updates from the admin area.</p>
        </div>
        <div class="process-grid">
            @foreach (var step in Model.ProcessSteps)
            {
                <article class="process-step">
                    <span>@step.Number</span>
                    <p class="eyebrow">@(step.IsPassengerTask ? "Passenger task" : "Review task")</p>
                    <h3>@step.Title</h3>
                    <p>@step.Description</p>
                </article>
            }
        </div>
    </section>
</section>
