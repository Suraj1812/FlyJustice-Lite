@page
@using System.Text.Json
@model FlyJusticeLite.Pages.FaqsModel
@{
    ViewData["Title"] = "Flight Compensation FAQs";
    ViewData["MetaDescription"] = "Answers about EU 261 compensation, delayed and cancelled flights, missed connections, documents, deadlines, extraordinary circumstances, and claim tracking.";
    var faqSchema = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "FAQPage",
        ["mainEntity"] = Model.Categories
            .SelectMany(category => category.Items)
            .Select(item => new Dictionary<string, object?>
            {
                ["@type"] = "Question",
                ["name"] = item.Question,
                ["acceptedAnswer"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Answer",
                    ["text"] = item.Answer
                }
            })
            .ToList()
    });
}

@section Head {
    <script type="application/ld+json">@Html.Raw(faqSchema)</script>
}

<section class="page-hero">
    <div class="container page-hero-inner">
        <p class="eyebrow eyebrow-light">Passenger help centre</p>
        <h1>Flight compensation questions, answered clearly.</h1>
        <p>Short, practical guidance on eligibility, compensation amounts, cancellations, refunds, documents, deadlines, route coverage, and claim progress.</p>
        <div class="page-hero-actions">
            <a class="button button-light" asp-page="/Index" asp-fragment="eligibility">Check eligibility</a>
            <a class="button button-ghost-light" asp-page="/Contact">Ask for support</a>
        </div>
    </div>
</section>

<section class="page-shell">
    <div class="container faq-layout" data-accordion>
        @foreach (var category in Model.Categories)
        {
            <section class="faq-category">
                <div class="faq-category-heading">
                    <p class="eyebrow">FAQ category</p>
                    <h2>@category.Name</h2>
                    <p>@category.Description</p>
                </div>
                <div class="faq-list">
                    @foreach (var item in category.Items)
                    {
                        <details>
                            <summary>@item.Question</summary>
                            <p>@item.Answer</p>
                            @if (item.Bullets is { Count: > 0 })
                            {
                                <ul class="check-list">
                                    @foreach (var bullet in item.Bullets)
                                    {
                                        <li>@bullet</li>
                                    }
                                </ul>
                            }
                        </details>
                    }
                </div>
            </section>
        }
    </div>
</section>
