@page
@model ErrorModel
@{
    ViewData["Title"] = "Something Went Wrong";
}

<section class="page-hero">
    <div class="container page-hero-inner">
        <p class="eyebrow eyebrow-light">Unexpected turbulence</p>
        <h1>We could not complete that request.</h1>
        <p>Try the action again. If the problem continues, use the support page and include the time and page where it happened.</p>
        <div class="page-hero-actions">
            <a class="button button-light" asp-page="/Index">Return home</a>
            <a class="button button-ghost-light" asp-page="/Contact">Contact support</a>
        </div>
    </div>
</section>
