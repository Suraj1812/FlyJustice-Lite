@page
@model FlyJusticeLite.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
    ViewData["MetaDescription"] = "Contact FlyJustice Lite about a passenger claim, claim number, or flight compensation workflow.";
}

<section class="container narrow stack-lg">
    <div class="page-heading">
        <p class="eyebrow">Contact</p>
        <h1>Send a claim support message.</h1>
        <p>Use this form for claim questions, document follow-up, or operational support. Include a claim number if you already have one.</p>
    </div>

    <form method="post" class="form-panel stack-md" data-loading-form>
        <partial name="_ValidationSummary" />

        <div class="form-grid">
            <div class="field">
                <label asp-for="Input.FullName"></label>
                <input asp-for="Input.FullName" autocomplete="name" />
                <span asp-validation-for="Input.FullName"></span>
            </div>
            <div class="field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email"></span>
            </div>
            <div class="field full">
                <label asp-for="Input.ClaimNumber"></label>
                <input asp-for="Input.ClaimNumber" placeholder="FJL-20260615-1001" autocomplete="off" />
                <span asp-validation-for="Input.ClaimNumber"></span>
            </div>
            <div class="field full">
                <label asp-for="Input.Message"></label>
                <textarea asp-for="Input.Message" rows="7"></textarea>
                <span class="field-hint">Minimum 20 characters. Avoid sharing unnecessary sensitive information.</span>
                <span asp-validation-for="Input.Message"></span>
            </div>
        </div>

        <div class="form-actions">
            <a class="button button-secondary" asp-page="/Claims/Track">Track claim</a>
            <button class="button button-primary" type="submit" data-submit-button data-loading-text="Sending...">
                Send message
            </button>
        </div>
    </form>
</section>
