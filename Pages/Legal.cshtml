@page "/Legal/{slug}"
@model FlyJusticeLite.Pages.LegalModel
@{
    ViewData["Title"] = Model.PageContent?.Title ?? "Legal";
    ViewData["MetaDescription"] = Model.PageContent?.Summary ?? "FlyJustice Lite legal, privacy, GDPR, terms, and operator information.";
}

@if (Model.PageContent is not null)
{
    <section class="page-hero">
        <div class="container page-hero-inner">
            <p class="eyebrow eyebrow-light">@Model.PageContent.Eyebrow</p>
            <h1>@Model.PageContent.Title</h1>
            <p>@Model.PageContent.Summary</p>
        </div>
    </section>

    <section class="page-shell">
        <div class="container article-layout">
            <article class="article-body">
                @foreach (var contentBlock in Model.PageContent.Sections)
                {
                    <section class="article-section">
                        <h2>@contentBlock.Heading</h2>
                        <p>@contentBlock.Body</p>
                    </section>
                }
                <section class="notice-panel">
                    <h2>Need clarification?</h2>
                    <p>Contact the operating claim team before submitting sensitive information or accepting commercial terms.</p>
                    <a class="button button-secondary" asp-page="/Contact">Contact support</a>
                </section>
            </article>
            <aside class="side-panel">
                <p class="eyebrow">Legal centre</p>
                <nav class="side-nav" aria-label="Legal pages">
                    @foreach (var legalPage in Model.Pages)
                    {
                        <a asp-page="/Legal" asp-route-slug="@legalPage.Slug">
                            @legalPage.Title
                            <svg class="icon"><use href="/images/icons.svg#chevron-right"></use></svg>
                        </a>
                    }
                </nav>
            </aside>
        </div>
    </section>
}
