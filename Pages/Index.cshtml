@page
@model IndexModel
@{
    ViewData["Title"] = "Check Eligibility";
    ViewData["MetaDescription"] = "Check flight delay compensation eligibility and start a FlyJustice Lite claim in minutes.";
}

<section class="container home-shell stack-lg">
    <div class="page-heading centered">
        <p class="eyebrow">Flight delay compensation</p>
        <h1>Check a passenger claim in under a minute.</h1>
        <p>Enter the core flight details to estimate compensation before opening a claim.</p>
    </div>

    <form method="post" class="form-panel eligibility-panel stack-md" data-loading-form>
        <partial name="_ValidationSummary" />

        <div class="form-grid">
            <div class="field">
                <label asp-for="Input.FlightNumber"></label>
                <input asp-for="Input.FlightNumber" autocomplete="off" placeholder="BA492" />
                <span asp-validation-for="Input.FlightNumber"></span>
            </div>
            <div class="field">
                <label asp-for="Input.Airline"></label>
                <input asp-for="Input.Airline" autocomplete="organization" placeholder="British Airways" />
                <span asp-validation-for="Input.Airline"></span>
            </div>
            <div class="field">
                <label asp-for="Input.DepartureAirport"></label>
                <input asp-for="Input.DepartureAirport" placeholder="London Heathrow" />
                <span asp-validation-for="Input.DepartureAirport"></span>
            </div>
            <div class="field">
                <label asp-for="Input.ArrivalAirport"></label>
                <input asp-for="Input.ArrivalAirport" placeholder="Gibraltar" />
                <span asp-validation-for="Input.ArrivalAirport"></span>
            </div>
            <div class="field full">
                <label asp-for="Input.DelayMinutes"></label>
                <input asp-for="Input.DelayMinutes" inputmode="numeric" min="0" max="1440" placeholder="315" />
                <span asp-validation-for="Input.DelayMinutes"></span>
            </div>
        </div>

        <button class="button button-primary button-wide" type="submit" data-submit-button data-loading-text="Checking...">
            Check Eligibility
        </button>
    </form>

    @if (Model.Result is not null)
    {
        <section class="result-panel @(Model.Result.IsEligible ? "result-success" : "result-neutral")" aria-live="polite">
            <div>
                <p class="eyebrow">@((Model.Result.IsEligible ? "Eligible estimate" : "Not eligible"))</p>
                <h2>@(Model.Result.IsEligible ? $"€{Model.Result.CompensationAmount:0}" : "No compensation estimate")</h2>
                <p>@Model.Result.Message</p>
            </div>

            @if (Model.Result.IsEligible)
            {
                <a class="button button-secondary" asp-page="/Claims/Submit"
                   asp-route-flightNumber="@Model.Input.FlightNumber"
                   asp-route-airline="@Model.Input.Airline"
                   asp-route-departureAirport="@Model.Input.DepartureAirport"
                   asp-route-arrivalAirport="@Model.Input.ArrivalAirport"
                   asp-route-delayMinutes="@Model.Input.DelayMinutes">
                    Continue to claim
                </a>
            }
        </section>
    }

    <section class="stats-strip" aria-label="Live claim metrics">
        <div>
            <span>@Model.Stats.TotalClaims.ToString("N0")</span>
            <p>claims tracked</p>
        </div>
        <div>
            <span>@Model.Stats.ApprovedClaims.ToString("N0")</span>
            <p>approved claims</p>
        </div>
        <div>
            <span>€@Model.Stats.PotentialCompensation.ToString("N0")</span>
            <p>potential compensation</p>
        </div>
        <div>
            <span>@Model.Stats.AverageDelayMinutes.ToString("N0") min</span>
            <p>average delay</p>
        </div>
    </section>

    <section class="section-band">
        <div class="page-heading centered">
            <p class="eyebrow">What we handle</p>
            <h2>Disruption support for common EU passenger claims.</h2>
            <p>Start with a simple eligibility check, then move into the right claim path for the disruption type.</p>
        </div>

        <div class="content-grid compact-grid">
            @foreach (var service in Model.Services)
            {
                <article class="content-card">
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                    <a class="text-link" href="@Url.Page(service.Page, new { slug = service.Slug })">@service.LinkText</a>
                </article>
            }
        </div>

        <div class="center-actions">
            <a class="button button-secondary" asp-page="/Services">View all services</a>
            <a class="button button-primary" asp-page="/Claims/Submit">Submit a claim</a>
        </div>
    </section>

    <section class="section-band">
        <div class="page-heading centered">
            <p class="eyebrow">How it works</p>
            <h2>A clean claim flow from evidence to status.</h2>
            <p>Passengers submit the facts once. The review team can then manage the claim from a focused admin area.</p>
        </div>

        <div class="process-grid">
            @foreach (var step in Model.ProcessSteps)
            {
                <article class="process-step">
                    <span>@step.Number</span>
                    <p class="eyebrow">@(step.IsPassengerTask ? "Passenger" : "Claim team")</p>
                    <h3>@step.Title</h3>
                    <p>@step.Description</p>
                </article>
            }
        </div>
    </section>

    <section class="trust-grid" aria-label="FlyJustice Lite trust and compliance">
        @foreach (var point in Model.TrustPoints)
        {
            <article class="trust-item">
                <h3>@point.Title</h3>
                <p>@point.Description</p>
            </article>
        }
    </section>

    <section class="faq-preview">
        <div class="page-heading centered">
            <p class="eyebrow">Passenger questions</p>
            <h2>Answers before you submit.</h2>
        </div>

        <div class="faq-list">
            @foreach (var item in Model.FaqPreview)
            {
                <details>
                    <summary>@item.Question</summary>
                    <p>@item.Answer</p>
                </details>
            }
        </div>

        <div class="center-actions">
            <a class="button button-secondary" asp-page="/Faqs">Read all FAQs</a>
        </div>
    </section>
</section>
