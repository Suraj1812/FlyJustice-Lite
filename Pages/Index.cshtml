@page
@model IndexModel
@{
    ViewData["Title"] = "Flight Compensation Claims";
    ViewData["MetaDescription"] = "Check whether a delayed or cancelled flight may qualify for up to EUR 600, submit evidence, and track the claim without creating an account.";
    ViewData["BodyClass"] = "home-page";
    ViewData["PreloadImage"] = "~/images/editorial/airport-hero.jpg";
}

<section class="hero" id="eligibility">
    <div class="container hero-inner">
        <div class="hero-copy">
            <p class="eyebrow eyebrow-light">EU passenger compensation</p>
            <h1>Claim up to EUR 600 for a disrupted flight.</h1>
            <p class="hero-lead">Check a delay, cancellation, missed connection, or denied boarding in minutes. No account, no upfront payment, and no dense legal language.</p>
            <ul class="hero-proof" aria-label="Service benefits">
                <li><svg class="icon"><use href="/images/icons.svg#check"></use></svg> Free eligibility check</li>
                <li><svg class="icon"><use href="/images/icons.svg#check"></use></svg> No win, no fee model</li>
                <li><svg class="icon"><use href="/images/icons.svg#check"></use></svg> Track without an account</li>
            </ul>
        </div>

        <form method="post" class="eligibility-hero" data-loading-form>
            <partial name="_ValidationSummary" />
            <div class="eligibility-grid">
                <div class="hero-field">
                    <label asp-for="Input.FlightNumber"></label>
                    <input asp-for="Input.FlightNumber" autocomplete="off" placeholder="BA492" />
                    <span asp-validation-for="Input.FlightNumber"></span>
                </div>
                <div class="hero-field">
                    <label asp-for="Input.Airline"></label>
                    <input asp-for="Input.Airline" autocomplete="organization" placeholder="British Airways" />
                    <span asp-validation-for="Input.Airline"></span>
                </div>
                <div class="hero-field">
                    <label asp-for="Input.DepartureAirport"></label>
                    <input asp-for="Input.DepartureAirport" placeholder="London Heathrow" />
                    <span asp-validation-for="Input.DepartureAirport"></span>
                </div>
                <div class="hero-field">
                    <label asp-for="Input.ArrivalAirport"></label>
                    <input asp-for="Input.ArrivalAirport" placeholder="Gibraltar" />
                    <span asp-validation-for="Input.ArrivalAirport"></span>
                </div>
                <div class="hero-field">
                    <label asp-for="Input.DelayMinutes"></label>
                    <input asp-for="Input.DelayMinutes" inputmode="numeric" min="0" max="1440" placeholder="315" />
                    <span asp-validation-for="Input.DelayMinutes"></span>
                </div>
                <button class="button button-primary" type="submit" data-submit-button data-loading-text="Checking...">
                    Check my flight
                    <svg class="icon"><use href="/images/icons.svg#arrow-right"></use></svg>
                </button>
            </div>
        </form>

        @if (Model.Result is not null)
        {
            <section class="hero-result" aria-live="polite">
                <div>
                    <p class="eyebrow eyebrow-light">@(Model.Result.IsEligible ? "Potential compensation" : "Eligibility result")</p>
                    <h2>@(Model.Result.IsEligible ? $"€{Model.Result.CompensationAmount:0}" : "Not eligible yet")</h2>
                    <p>@Model.Result.Message</p>
                </div>
                @if (Model.Result.IsEligible)
                {
                    <a class="button button-light" asp-page="/Claims/Submit"
                       asp-route-flightNumber="@Model.Input.FlightNumber"
                       asp-route-airline="@Model.Input.Airline"
                       asp-route-departureAirport="@Model.Input.DepartureAirport"
                       asp-route-arrivalAirport="@Model.Input.ArrivalAirport"
                       asp-route-delayMinutes="@Model.Input.DelayMinutes">
                        Start this claim
                        <svg class="icon"><use href="/images/icons.svg#arrow-right"></use></svg>
                    </a>
                }
            </section>
        }
    </div>
</section>

<section class="proof-bar" aria-label="Live FlyJustice claim statistics">
    <div class="container proof-bar-inner">
        <div class="proof-stat">
            <strong>@Model.Stats.TotalClaims.ToString("N0")</strong>
            <span>claims currently tracked</span>
        </div>
        <div class="proof-stat">
            <strong>@Model.Stats.ApprovedClaims.ToString("N0")</strong>
            <span>approved claim decisions</span>
        </div>
        <div class="proof-stat">
            <strong>€@Model.Stats.PotentialCompensation.ToString("N0")</strong>
            <span>potential compensation</span>
        </div>
        <div class="proof-stat">
            <strong>24/7</strong>
            <span>claim-number tracking</span>
        </div>
    </div>
</section>

<section class="airline-band" aria-label="Supported airlines">
    <p class="airline-intro">Claims across major European and international carriers</p>
    <div class="airline-rail">
        @foreach (var airline in Model.SupportedAirlines.Concat(Model.SupportedAirlines))
        {
            <span class="airline-chip">
                <span class="airline-code">@airline.Code</span>
                @airline.Name
            </span>
        }
    </div>
</section>

<section class="section">
    <div class="container story-layout">
        <div class="story-media">
            <img src="~/images/editorial/passenger-terminal.jpg"
                 alt="Passenger checking a departure board in a modern airport terminal"
                 width="1448"
                 height="1086"
                 loading="lazy"
                 decoding="async" />
            <div class="story-badge">
                <strong>3 hours</strong>
                <span>The usual arrival-delay threshold for cash compensation under EU 261.</span>
            </div>
        </div>
        <div class="story-copy">
            <p class="eyebrow">Know where you stand</p>
            <h2>A disrupted flight is stressful. The claim should not be.</h2>
            <p>FlyJustice turns the facts of your journey into a clear claim record. You provide the flight details and evidence once; the platform calculates an estimate and keeps every status update in one place.</p>
            <div class="story-points">
                <div class="story-point">
                    <span class="icon-tile"><svg class="icon"><use href="/images/icons.svg#route"></use></svg></span>
                    <div><h3>Route-aware eligibility</h3><p>Departure, arrival, airline, and final delay all shape EU 261 coverage.</p></div>
                </div>
                <div class="story-point">
                    <span class="icon-tile"><svg class="icon"><use href="/images/icons.svg#file-check"></use></svg></span>
                    <div><h3>Evidence in one place</h3><p>Upload a valid ticket, boarding pass, or booking confirmation from any device.</p></div>
                </div>
                <div class="story-point">
                    <span class="icon-tile"><svg class="icon"><use href="/images/icons.svg#shield-check"></use></svg></span>
                    <div><h3>Clear and GDPR-aware</h3><p>No public account profile and no unnecessary personal information.</p></div>
                </div>
            </div>
            <a class="button button-secondary" asp-page="/Rights">
                Explore passenger rights
                <svg class="icon"><use href="/images/icons.svg#arrow-right"></use></svg>
            </a>
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">What happened to your flight?</p>
            <h2>Start with the disruption, not the legal jargon.</h2>
            <p>Every guide explains the practical rights, useful evidence, and next step for that situation.</p>
        </div>
        <div class="rights-showcase">
            @foreach (var service in Model.Services)
            {
                <article class="rights-feature">
                    <p class="eyebrow">Passenger guide</p>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                    <a href="@Url.Page(service.Page, new { slug = service.Slug })">
                        @service.LinkText
                        <svg class="icon"><use href="/images/icons.svg#arrow-right"></use></svg>
                    </a>
                </article>
            }
        </div>
    </div>
</section>

<section class="section section-navy">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow eyebrow-light">A visible claim journey</p>
            <h2>From airport disruption to a tracked decision.</h2>
            <p>No mysterious case portal. Each step has a clear owner and a clear outcome.</p>
        </div>
        <div class="timeline">
            @foreach (var step in Model.ProcessSteps)
            {
                <article class="timeline-step">
                    <span class="timeline-marker">@step.Number</span>
                    <div>
                        <h3>@step.Title</h3>
                        <p>@step.Description</p>
                    </div>
                </article>
            }
        </div>

        <div class="compensation-scale" aria-label="Delay compensation bands">
            <div class="compensation-band"><strong>€250</strong><span>Typical eligible short-haul compensation</span></div>
            <div class="compensation-band"><strong>€400</strong><span>Typical eligible medium-haul compensation</span></div>
            <div class="compensation-band"><strong>€600</strong><span>Typical eligible long-haul compensation</span></div>
        </div>

        <div class="motion-story" aria-label="Animated claim journey">
            <div class="motion-copy">
                <p class="eyebrow eyebrow-light">Claim motion</p>
                <h3>One clear route from boarding pass to decision.</h3>
                <p>The visual timeline keeps the journey simple: details enter once, evidence stays private, and every status change is visible by claim number.</p>
            </div>
            <div class="motion-stage" aria-hidden="true">
                <span class="motion-node motion-node-start">
                    <svg class="icon"><use href="/images/icons.svg#file-check"></use></svg>
                </span>
                <span class="motion-path"></span>
                <span class="motion-plane">
                    <svg class="icon"><use href="/images/icons.svg#plane"></use></svg>
                </span>
                <span class="motion-node motion-node-end">
                    <svg class="icon"><use href="/images/icons.svg#euro"></use></svg>
                </span>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="trust-grid" aria-label="FlyJustice service principles">
            @foreach (var point in Model.TrustPoints)
            {
                <article class="trust-item">
                    <h3><svg class="icon"><use href="/images/icons.svg#shield-check"></use></svg>@point.Title</h3>
                    <p>@point.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container">
        <div class="section-heading centered">
            <p class="eyebrow">Passenger experiences</p>
            <h2>Clarity matters when travel plans fall apart.</h2>
        </div>
        <div class="testimonial-grid">
            @foreach (var story in Model.PassengerStories)
            {
                <article class="testimonial">
                    <span class="quote-icon"><svg class="icon"><use href="/images/icons.svg#quote"></use></svg></span>
                    <blockquote>“@story.Quote”</blockquote>
                    <footer>
                        <strong>@story.Passenger</strong>
                        <span>@story.Route</span>
                    </footer>
                    <p class="outcome">@story.Outcome</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Recent claim patterns</p>
            <h2>Realistic routes. Structured evidence. Clear outcomes.</h2>
        </div>
        <div class="success-grid">
            @foreach (var story in Model.SuccessStories)
            {
                <article class="success-story">
                    <span class="route">@story.Route</span>
                    <p>@story.Disruption</p>
                    <p>@story.Resolution</p>
                    <strong>@story.Amount</strong>
                </article>
            }
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container">
        <div class="section-heading centered">
            <p class="eyebrow">Common questions</p>
            <h2>Useful answers before you submit.</h2>
        </div>
        <div class="faq-list narrow" data-accordion>
            @foreach (var item in Model.FaqPreview)
            {
                <details>
                    <summary>@item.Question</summary>
                    <p>@item.Answer</p>
                </details>
            }
        </div>
        <div class="center-actions">
            <a class="button button-secondary" asp-page="/Faqs">Read all passenger FAQs</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="container cta-band">
        <div>
            <h2>Still have your ticket or booking confirmation?</h2>
            <p>That is enough to start a structured compensation claim.</p>
        </div>
        <a class="button button-light" asp-page="/Claims/Submit">
            Submit a claim
            <svg class="icon"><use href="/images/icons.svg#arrow-right"></use></svg>
        </a>
    </div>
</section>
