@page
@model FlyJusticeLite.Pages.WhyChooseUsModel
@{
    ViewData["Title"] = "Why Choose FlyJustice";
    ViewData["MetaDescription"] = "A passenger-first flight compensation experience with clear eligibility, no account barrier, GDPR-aware handling, evidence upload, and transparent tracking.";
}

<section class="page-hero">
    <div class="container page-hero-inner">
        <p class="eyebrow eyebrow-light">Why FlyJustice</p>
        <h1>Serious claim handling without a heavy experience.</h1>
        <p>Passengers get a fast, understandable journey. Review teams get structured records, validated evidence, and a focused decision workflow.</p>
        <div class="page-hero-actions">
            <a class="button button-light" asp-page="/Claims/Submit">Start a claim</a>
            <a class="button button-ghost-light" asp-page="/Fees">See the fee model</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="trust-grid">
            @foreach (var point in Model.TrustPoints)
            {
                <article class="trust-item">
                    <h3><svg class="icon"><use href="/images/icons.svg#check"></use></svg>@point.Title</h3>
                    <p>@point.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container story-layout">
        <div class="claim-aside-panel">
            <p class="eyebrow eyebrow-light">Passenger experience</p>
            <h2>No login wall between a passenger and their claim.</h2>
            <p>Submission creates a single claim reference. That reference is enough to view progress without managing a password or profile.</p>
        </div>
        <div class="story-copy">
            <p class="eyebrow">Operational quality</p>
            <h2>The simple front end is supported by structured case data.</h2>
            <ul class="check-list">
                <li>Server-side validation for every claim field</li>
                <li>Private document storage with file-signature checks</li>
                <li>Searchable claim records and pagination</li>
                <li>Clear Pending, Under Review, Approved, and Rejected states</li>
            </ul>
        </div>
    </div>
</section>
